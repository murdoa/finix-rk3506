CONFIG_BASE_DEFCONFIG="rockchip-usbplug_defconfig"
# Override base SoC — we're RK3506, not RV1126
# CONFIG_ROCKCHIP_RV1126 is not set
# CONFIG_TARGET_EVB_RV1126 is not set
CONFIG_ROCKCHIP_RK3506=y
CONFIG_TARGET_EVB_RK3506=y
CONFIG_DEFAULT_DEVICE_TREE="rk3506-luckfox"
CONFIG_SYS_BOARD="evb_rk3506"
CONFIG_SYS_CONFIG_NAME="evb_rk3506"
# Debug UART: FIQ debugger on UART0 @ 0xff0a0000
CONFIG_DEBUG_UART_BASE=0xff0a0000
CONFIG_DEBUG_UART_CLOCK=24000000
CONFIG_DEBUG_UART_SHIFT=2
CONFIG_BAUDRATE=1500000
# Storage: SPI NAND via Rockchip SFC
CONFIG_ROCKCHIP_SFC=y
CONFIG_MTD=y
CONFIG_MTD_BLK=y
CONFIG_MTD_DEVICE=y
CONFIG_MTD_SPI_NAND=y
CONFIG_SPI_FLASH=y
CONFIG_SF_DEFAULT_MODE=0x1
CONFIG_SF_DEFAULT_SPEED=50000000
CONFIG_SPI_FLASH_SFDP_SUPPORT=y
CONFIG_SPI_FLASH_WINBOND=y
CONFIG_SPI_FLASH_GIGADEVICE=y
CONFIG_SPI_FLASH_MACRONIX=y
CONFIG_SPI_FLASH_XMC=y
CONFIG_SPI_FLASH_MTD=y
CONFIG_ROCKCHIP_NEW_IDB=y
# USB gadget: DWC2 OTG (not DWC3)
# CONFIG_USB_DWC3 is not set
# CONFIG_USB_DWC3_GADGET is not set
CONFIG_USB_GADGET_DWC2_OTG=y
CONFIG_USB_GADGET_PRODUCT_NUM=0x350f
CONFIG_USB_GADGET_VBUS_DRAW=500
# Clocks and pinctrl needed for SFC and USB
CONFIG_CLK=y
CONFIG_PINCTRL=y
CONFIG_PINCTRL_ROCKCHIP=y
CONFIG_ROCKCHIP_GPIO=y
CONFIG_ROCKCHIP_GPIO_V2=y
CONFIG_PHY_ROCKCHIP_INNO_USB2=y
# DM basics
CONFIG_REGMAP=y
CONFIG_SYSCON=y
# MMC not needed for usbplug but keep it available for detection
CONFIG_MMC_DW=y
CONFIG_MMC_DW_ROCKCHIP=y
# Needed for CMD_ROCKUSB
CONFIG_CMD_ROCKUSB=y
# SYSRESET for rbrom if needed
CONFIG_SYSRESET=y
